    "e2e:usdy": "bun run src/e2e-usdy.ts"
  },
  "dependencies": {
    "@cetusprotocol/aggregator-sdk": "^1.6.1",
    "@mysten/sui": "^2.17.0",
    "bn.js": "^5.2.3"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
