{
  "name": "sweem-scripts",
  "private": true,
  "type": "module",
  "description": "Bun + TypeScript runtime FLOW TESTS against already-deployed Sweem contracts. NO deploy/publish logic — the maintainer publishes manually and fills deployed.json.",
  "scripts": {
