# scripts/.env.example — copy to scripts/.env and fill in.
# .env is gitignored. NEVER commit a real key.

# Bech32 Sui private key ("suiprivkey1...") for the signer.
# Export from the CLI:  sui keytool export --key-identity <alias>
# Decoded via decodeSuiPrivateKey / Ed25519Keypair.fromSecretKey.
SUI_PRIVATE_KEY=suiprivkey1...

# Network: mainnet (default) or testnet. Sweem mainnet IDs assume mainnet.
SUI_NETWORK=mainnet

# Set EXECUTE=1 to actually sign+submit. Default (unset / 0) = DRY RUN: builds
# the Transaction and prints it, hits no chain. The --execute CLI flag does the same.
EXECUTE=0

# ----- Identities (all optional; default to the signer's own address) ---------
# ADMIN must equal the signer for admin-setup + pool org-side calls.
# TREASURY defaults to ADMIN. E1/E2/E3 are employee stream recipients.
# ADMIN=0x...
# TREASURY=0x...
# E1=0x...
# E2=0x...
# E3=0x...

# ----- Amount overrides (raw, 6-decimal USDC) — defaults honor the 5 USDC floor
# DEPOSIT_AMOUNT=30000000
# NAVI_INVEST_AMOUNT=6000000
# SCALLOP_INVEST_AMOUNT=5000000
# STREAM_RATE_AMOUNT=1000000
# STREAM_RATE_PERIOD_MS=2592000000
# MIN_COVERAGE_WEEKS=1
# REBAL_AMOUNT=5000000
# VAULT_DEPOSIT_AMOUNT=12000000
# VAULT_NAVI_AMOUNT=6000000
# VAULT_SCALLOP_AMOUNT=5000000
# VAULT_TOKEN_NAME=USDC

# ----- Coin selection --------------------------------------------------------
# COIN_TYPE override (default mainnet native USDC).
# COIN_TYPE=0xdba34672e30cb065b1f93e3ab55318768fd6fef66c15942c9f7cb846e2f900e7::usdc::USDC
# COIN_OBJECT pins a specific funding Coin<COIN_TYPE>; otherwise the largest owned is used.
# COIN_OBJECT=0x...
